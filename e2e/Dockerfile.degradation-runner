# Build stage
FROM golang:1.24 as builder
WORKDIR /app
# Module files
COPY e2e/go.mod e2e/go.sum ./ 
RUN go mod download
# Copy source
COPY e2e/ ./ 
# Build the degradation finder
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /degradation ./cmd/degradation_many_user_test

# Runtime stage
FROM alpine:3.20
RUN adduser -D -u 10001 appuser
USER appuser
WORKDIR /home/appuser
COPY --from=builder /degradation /usr/local/bin/degradation
ENTRYPOINT ["/usr/local/bin/degradation"]


